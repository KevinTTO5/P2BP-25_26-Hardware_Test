# laptop/config/laptop.env.example
#
# Operator-facing environment file for the DS 9.0 laptop scripted testing
# harness. `00_bootstrap.sh` copies this file to laptop/config/laptop.env on
# first run (prompting interactively; subsequent runs reuse existing values,
# following the same pattern as install.sh lines 48-109).
#
# Scope: Notion page 337b5d58-7212-81e1-b07a-d510d9605bbb Sections 5-10.
# Sections 1-4: place the required .deb files (see DEEPSTREAM-SETUP.md §4) in
# LOCAL_DEB_DIR before Phases 2b–3; 00_bootstrap.sh installs the NVIDIA stack
# and DS 9.0 in phased order. To remove that install: run
#   sudo bash laptop/scripts/00_bootstrap.sh --uninstall
# (optional: --purge-env to delete this file; --yes or UNINSTALL_ASSUME_YES=1
# skips the confirmation prompt).

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Directory for pre-downloaded NVIDIA .deb files (Phases 2b–3, 6). Default when
# running `sudo ./00_bootstrap.sh` is the invoking user's ~/Downloads. Override
# here, or use: sudo ./00_bootstrap.sh --local-deb-dir /path
LOCAL_DEB_DIR=$HOME/Downloads

# IPv4 address the laptop exposes on the camera LAN. Used in the AMC
# compose/.env so the AMC web UI is reachable from the same host, and by
# 50_start_pipeline.sh when printing monitoring helpers.
HOST_IP=192.168.10.10

# Short identifier for this deployment/site (no spaces). Used as the AMC
# project name and as the calibration subdirectory under
# laptop/deepstream/calibration/<LOCATION_ID>/.
LOCATION_ID=test-lab-01

# Camera RTSP credentials. Matches the defaults the Hikvision/Amcrest-style
# cameras in Notion §7.2 ship with. Override per deployment.
CAM_USER=admin
CAM_PASSWORD=Placemaking25

# NGC API key (from https://ngc.nvidia.com). Used for:
#   - `docker login nvcr.io` in 30_start_amc.sh to pull AMC container images.
#   - Phase 10 of 00_bootstrap.sh (PeopleNet ONNX via ngc registry model
#     download-version), when set non-interactive ~/.ngc/config is written.
# Leave blank if you already ran `docker login nvcr.io` and configured ngc.
NGC_API_KEY=

# AMC project name. Typically the same as LOCATION_ID; exposed separately so a
# single laptop can run multiple AMC projects side-by-side if needed.
PROJECT_NAME=test-lab-01

# ---------------------------------------------------------------------------
# Pinned detector
# ---------------------------------------------------------------------------
# PeopleNet is the only detector installed and wired into the pipeline. This
# matches NVIDIA's DS 9.0 MV3DT reference documentation
# (DS_MV3DT.html from the deepstream-9-docs skill). It is intentionally NOT
# operator-selectable via prompt.
#
# `yolo11n` (ultralytics yolo11n.pt) is the ONLY approved alternative
# detector for future work. No script in laptop/scripts/ installs, exports,
# or configures it. See laptop/deepstream/config_infer_primary.txt header for
# the future-work pointer.
DETECTOR=peoplenet

# NGC tag for PeopleNet ONNX — pulled by Phase 10 of 00_bootstrap.sh. Override
# to pin a different build. Notion §9.3 Option A.
PEOPLENET_NGC_TAG=nvidia/tao/peoplenet:deployable_quantized_onnx_v2.6.3

# ---------------------------------------------------------------------------
# AMC runtime
# ---------------------------------------------------------------------------
# Where NVIDIA-AI-IOT/auto-magic-calib gets cloned by 30_start_amc.sh.
# MUST be outside this repo's working tree; never point inside laptop/.
AMC_ROOT=$HOME/auto-magic-calib

# AMC compose/.env variable names per Notion §8.3-8.4. Verified against the
# upstream AMC repo at run time (30_start_amc.sh reads the AMC repo's own
# .env.example and warns if any key here has been renamed upstream).
AUTO_MAGIC_CALIB_MS_PORT=8000
AUTO_MAGIC_CALIB_UI_PORT=5000

# ---------------------------------------------------------------------------
# Mosquitto
# ---------------------------------------------------------------------------
# Topic base for the MV3DT publishers (nvmsgbroker -> libnvds_mqtt_proto.so).
# deepstream_app_config.txt's [sink0] expands this to
# mv3dt/<LOCATION_ID>/sv3d and mv3dt/<LOCATION_ID>/fused.
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_BASE=mv3dt
